MONGODB_DBNAME=nuzlocke-tracker
MONGODB_USERNAME=<username>
MONGODB_PASSWORD=<password>
MONGODB_HOST=<cluster>.mongodb.net
MONGODB_AUTH_SOURCE=admin
MONGODB_AUTH_MECHANISM=SCRAM-SHA-1

# Or use a single connection string instead:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nuzlocke-tracker?retryWrites=true&w=majority
